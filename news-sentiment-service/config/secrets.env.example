# Пример конфига для токенов Telethon, прокси и сессий

# --- Telegram (режим telethon; для режима web не нужны) ---
# Получить на https://my.telegram.org -> API development tools
TELETHON_API_ID=123456
TELETHON_API_HASH=your_api_hash
# Строковая сессия (StringSession) — опционально. Если пусто, используется
# файловая сессия с именем TELEGRAM_SESSION_NAME.
TELETHON_SESSION=
TELEGRAM_SESSION_NAME=news_sentiment_tg
# Список каналов через запятую: @username или https://t.me/username
TELEGRAM_CHANNELS=durov,telegram

# --- Twitter/X (Playwright с авторизацией) ---
# Путь к JSON storage_state, экспортированному из залогиненного браузера.
# См. docstring TwitterScraper о том, как получить файл.
TWITTER_STORAGE_STATE=
# Список целей через запятую: @username или поисковый запрос
TWITTER_TARGETS=Bitcoin,elonmusk

RABBITMQ_URL=amqp://guest:guest@localhost:5672/
DATABASE_URL=sqlite:///./news_sentiment.db
OPENAI_API_KEY=your_api_key
HTTP_PROXY=
HTTPS_PROXY=
